FROM python:3.11-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Application code — pulls in data/models/ and data/team_ids.json from the
# local build context since .dockerignore (unlike .gitignore) keeps them in.
COPY . .

RUN mkdir -p data/raw data/processed logs

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

EXPOSE 10000
CMD ["sh", "-c", "gunicorn -w 2 -b 0.0.0.0:${PORT:-10000} --timeout 120 webapp.app:app"]
