# ============================================================
# Sports Predictor - Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# Football-Data.org (free tier: 10 req/min)
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# API-Sports (api-football, api-basketball, api-tennis)
# Free tier: 100 req/day
API_SPORTS_KEY=your_api_sports_key_here
RAPIDAPI_KEY=your_rapidapi_key_here

# Basketball data (optional)
BALLDONTLIE_API_KEY=your_balldontlie_key_here

# The Odds API (free tier: 500 req/month)
ODDS_API_KEY=your_odds_api_key_here
# Optional key pool for true fresh rescans (comma-separated or one per line)
ODDS_API_KEYS=key1,key2,key3,key4

# OpenWeather (optional, for outdoor match risk)
OPENWEATHER_API_KEY=your_openweather_key_here

# Telegram alerts (optional)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Bankroll settings
INITIAL_BANKROLL=1000.0
